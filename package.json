{
  "name": "table-tennis-event-system-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "乒乓球赛事管理前端（Vue 2.7 + Vite 2.9）；后端见 tt-admin-api（Java 17 + Spring Boot 3.2.5）",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:portal": "vite build --config client/vite.portal.config.js",
    "build:admin": "vite build --config client/vite.admin.config.js",
    "build:all": "npm run build:portal && npm run build:admin",
    "dev:portal": "vite --config client/vite.portal.config.js",
    "dev:admin": "vite --config client/vite.admin.config.js",
    "preview:portal": "vite preview --config client/vite.portal.config.js --port 4173",
    "preview:admin": "vite preview --config client/vite.admin.config.js --port 4174",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"client/admin/**/*.vue\" \"client/admin/**/*.js\" \"client/portal/**/*.vue\" \"client/portal/**/*.js\" \"client/shared/**/*.js\"",
    "lint:fix": "eslint \"client/admin/**/*.vue\" \"client/admin/**/*.js\" \"client/portal/**/*.vue\" \"client/portal/**/*.js\" \"client/shared/**/*.js\" --fix"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "element-ui": "^2.15.14",
    "i18n-iso-countries": "^7.14.0",
    "vant": "^2.13.9",
    "vue": "^2.7.16",
    "vue-router": "^3.6.5",
    "vue-template-compiler": "^2.7.16"
  },
  "devDependencies": {
    "@vue/test-utils": "^1.3.6",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "jsdom": "^22.1.0",
    "vite": "2.9.18",
    "vite-plugin-vue2": "1.9.3",
    "vitest": "^0.34.6"
  }
}
