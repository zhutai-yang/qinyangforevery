# 复制为 .env 后由 docker compose 与 Vite 共用（仓库根目录）
# 首次：make env  或  cp .env.example .env
#
# 默认端口刻意与 IMP（3306/5672/15672/8080）错开，可同机并行。
COMPOSE_PROJECT_NAME=tt-event

# ========== 前端 Vite（本地 dev，非 Docker） ==========
# VITE_API_TARGET=http://127.0.0.1:8096
# VITE_ADMIN_PORT=5174

# ========== MySQL（宿主机映射端口 → 容器 3306） ==========
MYSQL_ROOT_PASSWORD=ttdevroot
MYSQL_PORT=3307
DB_NAME=tt_event
DB_USERNAME=tt_user
DB_PASSWORD=ttsecret

# ========== RabbitMQ（宿主机映射 → 容器 5672/15672） ==========
RABBITMQ_USERNAME=tt
RABBITMQ_PASSWORD=ttsecret
RABBITMQ_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673

# ========== 应用 ==========
TT_JWT_SECRET=please-change-to-256-bit-secret-key-for-production-min-32chars!!
ADMIN_INITIAL_PASSWORD=admin123
TT_SYNC_MODE=direct
TT_SYNC_SCHEDULER_ENABLED=true
TT_SYNC_SCHEDULER_DELAY_MS=60000

# ========== 对外端口 ==========
HTTP_PORT=8888
API_PORT=8096

# ========== 阿里云 ECS 公网部署（make up-ecs / scripts/ecs-deploy.sh）==========
# HTTP_PORT=80
# TT_SYNC_MODE=direct
# 安全组仅放行 22、80；MySQL/RabbitMQ/API 已绑定 127.0.0.1，不对外暴露
# 首次：bash scripts/ecs-bootstrap.sh && bash scripts/ecs-deploy.sh

# 本地 mvn 连 Docker MySQL 时使用：
# DB_HOST=127.0.0.1 DB_PORT=3307 DB_USERNAME=tt_user DB_PASSWORD=ttsecret
